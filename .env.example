APP_NAME=PgBetterAuth Starter
DATABASE_URL=postgresql://user:password@host:5432/dbname
BETTER_AUTH_SECRET=replace-with-32-char-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional: if HUBMAIL_KEY is omitted, auth emails are logged to the server console.
HUBMAIL_KEY=hm_your_api_key
AUTH_EMAIL_FROM=no-reply@example.com
